# 뮤런 reverse proxy.
#
# DOMAIN 환경변수에 따라:
#   - 도메인 미설정시: ":80"  → 자동 HTTP 만 (개발/임시)
#   - duckdns 등 도메인 설정시: "murun.duckdns.org" → Let's Encrypt 자동 HTTPS

{$DOMAIN} {
	encode zstd gzip

	# Next.js _next/static 은 long cache
	@nextStatic path /_next/static/*
	header @nextStatic Cache-Control "public, max-age=31536000, immutable"

	# 보안 헤더 (느슨한 기본값. 도메인 붙은 후 CSP 추가 예정)
	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
		-Server
	}

	reverse_proxy app:3000 {
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}
	}
}
