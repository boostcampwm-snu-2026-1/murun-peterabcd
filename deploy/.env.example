# deploy/.env — N100 호스트에서 compose 가 읽는 환경변수.
# repo에는 example 만, 실제 값은 호스트의 deploy/.env (gitignore됨).

# --- compose 자체 ---
IMAGE_TAG=local

# --- Caddy ---
# 도메인 붙이기 전: :80 (자동 HTTP만, 인증서 발급 시도 안 함)
# 도메인 붙은 후:  murun.duckdns.org  (Let's Encrypt 자동)
DOMAIN=:80
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# --- App 환경변수는 app 서비스의 env_file 로 별도 ---
# 즉, deploy/.env 와 별개로 app 가 읽을 .env 가 같은 디렉터리에 있어야 함.
# (구성: deploy/.env  ← compose용,   deploy/app.env  ← app 컨테이너용)
# 다음 PR에서 Prisma/Auth.js 키 들어오면 env_file 경로 갱신 예정.
