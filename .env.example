# ---------------------------------------------------------------------------
# 뮤런 환경변수 템플릿. cp .env.example .env.local 후 채워 넣기.
# 실제 값은 절대 commit 금지. .env.local 은 .gitignore 됨.
# ---------------------------------------------------------------------------

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (SQLite, 후속 PR에서 추가) ---
# DATABASE_URL=file:./data/murun.db

# --- Auth.js v5 (후속 PR에서 추가) ---
# NEXTAUTH_URL=http://localhost:3000
# # 생성: openssl rand -base64 32
# NEXTAUTH_SECRET=

# --- Google OAuth (후속 PR에서 추가) ---
# # Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# # Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# # 이메일 도메인 강제: 다른 hd 로그인은 reject
# GOOGLE_HD=snu.ac.kr

# --- Uploads (후속 PR에서 추가) ---
# UPLOADS_DIR=./uploads
